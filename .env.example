# ──────────────────────────────────────────────────────────
#  SPP-Gamma  ·  Environment Variables  ·  v1.1
# ──────────────────────────────────────────────────────────

PORT=3000

# Gemini API Key (fallback / dev sin OAuth)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Session secret (genera uno largo y aleatorio)
SESSION_SECRET=cambiar_esto_por_un_secreto_largo_aleatorio

# Google OAuth 2.0  (console.cloud.google.com → Credenciales → OAuth 2.0)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Dominio corporativo permitido (deja vacío para permitir cualquier Gmail)
ALLOWED_DOMAIN=gammaingenieros.com

# Admin local: crea un usuario con email + contraseña (bcrypt hash generado al arrancar)
ADMIN_EMAIL=admin@gammaingenieros.com
ADMIN_PASSWORD=Gamma2024!
